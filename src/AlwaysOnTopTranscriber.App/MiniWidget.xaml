<Window x:Class="AlwaysOnTopTranscriber.App.MiniWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcriber Widget"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="348"
        Height="176"
        Left="80"
        Top="80">
    <Border CornerRadius="14"
            Background="#1F2937"
            BorderBrush="#374151"
            BorderThickness="1"
            Opacity="0.95"
            MouseLeftButtonDown="WidgetSurface_OnMouseLeftButtonDown">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="88" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Mini widget"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="#F3F4F6"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    x:Name="CloseButton"
                    Padding="6,2"
                    Height="24"
                    HorizontalAlignment="Right"
                    Content="Ukryj"
                    Background="#334155"
                    Foreground="#E5E7EB"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Click="CloseButton_OnClick"
                    Cursor="Hand" />

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="128" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SessionNameTextBox"
                         Height="32"
                         VerticalContentAlignment="Center"
                         FontSize="12"
                         Padding="8,0,8,0"
                         Background="#233251"
                         BorderBrush="#3B82F6"
                         Foreground="#E5E7EB"
                         ToolTip="Nazwa sesji" />

                <ComboBox Grid.Column="1"
                          x:Name="LanguageComboBox"
                          Height="32"
                          Margin="8,0,0,0"
                          SelectedIndex="0"
                          FontSize="12"
                          Background="#233251"
                          BorderBrush="#3B82F6"
                          Foreground="#E5E7EB"
                          SelectionChanged="LanguageComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="Auto" Tag="auto" />
                    <ComboBoxItem Content="Polish" Tag="pl" />
                    <ComboBoxItem Content="English" Tag="en" />
                </ComboBox>
            </Grid>

            <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartStopButton"
                        Content="Start"
                        Height="32"
                        Background="#10B981"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Click="StartStopButton_OnClick"
                        Cursor="Hand" />

                <TextBlock Grid.Column="1"
                           x:Name="ElapsedTimeTextBlock"
                           Text="00:00:00"
                           Foreground="#E5E7EB"
                           FontSize="12"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />

                <TextBlock Grid.Column="2"
                           x:Name="StatusIndicatorTextBlock"
                           Text="Ready"
                           Foreground="#9CA3AF"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>

            <ProgressBar Grid.Row="3"
                         Grid.ColumnSpan="2"
                         x:Name="AudioLevelBar"
                         Minimum="0"
                         Maximum="100"
                         Height="7"
                         Margin="0,8,0,0"
                         Background="#374151"
                         Foreground="#34D399" />
        </Grid>
    </Border>
</Window>
