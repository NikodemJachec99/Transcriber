<Window x:Class="AlwaysOnTopTranscriber.App.MiniWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcriber Widget"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="380"
        Height="120"
        Left="80"
        Top="80">
    <Border CornerRadius="12" Background="#1F2937" BorderBrush="#374151" BorderThickness="1" Opacity="0.92">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock x:Name="SessionNameTextBlock"
                       Text="Nowa sesja"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#F3F4F6"
                       TextTrimming="CharacterEllipsis" />

            <!-- Close/Minimize Button -->
            <Button Grid.Column="1"
                    Padding="6,2"
                    Height="24"
                    HorizontalAlignment="Right"
                    Content="✕"
                    Background="#EF4444"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Click="CloseButton_OnClick"
                    Cursor="Hand" />

            <!-- Time and Audio Level Row -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="⏱ " Foreground="#9CA3AF" FontSize="11" />
                <TextBlock Grid.Column="1"
                           x:Name="ElapsedTimeTextBlock"
                           Text="00:00:00"
                           Foreground="#E5E7EB"
                           FontSize="11"
                           FontFamily="Consolas"
                           Margin="2,0,0,0" />
                <TextBlock Grid.Column="2"
                           x:Name="StatusIndicatorTextBlock"
                           Text="● Ready"
                           Foreground="#9CA3AF"
                           FontSize="10"
                           TextAlignment="Right" />
            </Grid>

            <!-- Audio Level Bar -->
            <ProgressBar Grid.Row="2"
                         x:Name="AudioLevelBar"
                         Minimum="0"
                         Maximum="100"
                         Height="6"
                         Margin="0,6,0,0"
                         Background="#374151"
                         Foreground="#10B981" />

            <!-- Start/Stop Button -->
            <Button Grid.Row="2"
                    Grid.Column="1"
                    x:Name="StartStopButton"
                    Content="Start"
                    Height="32"
                    Margin="0,0,0,0"
                    Background="#10B981"
                    Foreground="White"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Click="StartStopButton_OnClick"
                    Cursor="Hand" />

            <!-- Drag Handle -->
            <TextBlock Text="≡"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Foreground="#6B7280"
                       FontSize="10"
                       Margin="3,2,0,0"
                       Cursor="Move"
                       MouseDown="DragHandle_OnMouseDown"
                       Panel.ZIndex="100" />
        </Grid>
    </Border>
</Window>
