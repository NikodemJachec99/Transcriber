<Window x:Class="AlwaysOnTopTranscriber.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcriber v1.2 (Lite)"
        Width="980"
        Height="700"
        MinWidth="840"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" CornerRadius="10" Background="#F4F6FA" BorderThickness="1" BorderBrush="#DDE3EF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Transcriber v1.2 Lite"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />
                    <TextBlock x:Name="DataPathText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#4B5563" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="OpenDataFolderButton"
                        Content="Otwórz folder danych"
                        Height="34"
                        Width="180"
                        Margin="12,0,0,0"
                        Click="OpenDataFolderButton_OnClick" />
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,12,0,12">
            <TabItem Header="Live">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Nazwa sesji" FontWeight="SemiBold" />
                            <TextBox x:Name="SessionNameTextBox" Height="34" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Język" FontWeight="SemiBold" />
                            <ComboBox x:Name="LanguageComboBox" Height="34">
                                <ComboBoxItem Content="Auto" Tag="auto" />
                                <ComboBoxItem Content="Polish" Tag="pl" />
                                <ComboBoxItem Content="English" Tag="en" />
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="2"
                                x:Name="StartStopButton"
                                Content="Start"
                                Height="34"
                                Margin="0,20,0,0"
                                Background="#10B981"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Click="StartStopButton_OnClick" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="10,8" CornerRadius="8" Background="#EEF2FF" BorderBrush="#DDE3EF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="11" Foreground="#4B5563" />
                                <TextBlock x:Name="StatusTextBlock" Text="Ready" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="10,8"
                                CornerRadius="8"
                                Background="#EEF2FF"
                                BorderBrush="#DDE3EF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Czas" FontSize="11" Foreground="#4B5563" />
                                <TextBlock x:Name="ElapsedTextBlock" Text="00:00:00" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="10,8"
                                CornerRadius="8"
                                Background="#EEF2FF"
                                BorderBrush="#DDE3EF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Poziom audio" FontSize="11" Foreground="#4B5563" />
                                <ProgressBar x:Name="AudioLevelBar" Minimum="0" Maximum="100" Height="14" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="10"
                            CornerRadius="8"
                            Background="#FEF3C7"
                            BorderBrush="#F59E0B"
                            BorderThickness="1">
                        <TextBlock x:Name="WarningTextBlock"
                                   Text=""
                                   Foreground="#92400E"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBox Grid.Row="3"
                             x:Name="TranscriptTextBox"
                             Margin="0,12,0,0"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             IsReadOnly="True" />
                </Grid>
            </TabItem>

            <TabItem Header="Ustawienia">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Model Whisper" FontWeight="SemiBold" />
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ModelComboBox" Height="34" DisplayMemberPath="Name" SelectedValuePath="Name" />
                        <Button Grid.Column="1" x:Name="RefreshModelsButton" Margin="10,0,0,0" Content="Odśwież" Click="RefreshModelsButton_OnClick" />
                        <Button Grid.Column="2" x:Name="DownloadModelButton" Margin="10,0,0,0" Content="Pobierz model" Click="DownloadModelButton_OnClick" />
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Własny plik modelu (.bin)" Margin="0,12,0,0" FontWeight="SemiBold" />
                    <Grid Grid.Row="3" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CustomModelPathTextBox" Height="34" />
                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Wybierz..." Click="BrowseModelButton_OnClick" />
                    </Grid>

                    <TextBlock Grid.Row="4" x:Name="ModelStatusTextBlock" Margin="0,12,0,0" Foreground="#1F2937" />
                    <ProgressBar Grid.Row="5" x:Name="DownloadProgressBar" Margin="0,6,0,0" Height="16" Minimum="0" Maximum="100" />

                    <StackPanel Grid.Row="6" Margin="0,14,0,0">
                        <Button x:Name="SaveSettingsButton"
                                Width="180"
                                Height="34"
                                Content="Zapisz ustawienia"
                                Click="SaveSettingsButton_OnClick" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Sesje">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RefreshSessionsButton"
                                Content="Odśwież sesje"
                                Height="34"
                                Click="RefreshSessionsButton_OnClick" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Content="Folder sesji"
                                Height="34"
                                Click="OpenTranscriptsFolderButton_OnClick" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Content="Otwórz TXT"
                                Height="34"
                                Click="OpenSelectedTextButton_OnClick" />
                        <TextBlock Grid.Column="3"
                                   Margin="10,8,0,0"
                                   x:Name="SessionsInfoTextBlock"
                                   Foreground="#4B5563" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              Margin="0,12,0,0"
                              x:Name="SessionsDataGrid"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="220" />
                            <DataGridTextColumn Header="Start" Binding="{Binding StartLocal}" Width="160" />
                            <DataGridTextColumn Header="Czas" Binding="{Binding DurationText}" Width="90" />
                            <DataGridTextColumn Header="Model" Binding="{Binding ModelName}" Width="100" />
                            <DataGridTextColumn Header="Plik TXT" Binding="{Binding TextPath}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="FooterStatusTextBlock" Text="Gotowe." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
