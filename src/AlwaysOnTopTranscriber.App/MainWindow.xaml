<Window x:Class="AlwaysOnTopTranscriber.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcriber v1.2 (Lite)"
        Width="980"
        Height="700"
        MinWidth="840"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" CornerRadius="10" Background="#F4F6FA" BorderThickness="1" BorderBrush="#DDE3EF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Transcriber v1.2 Lite"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />
                    <TextBlock x:Name="DataPathText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#4B5563" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="ShowMiniWidgetButton"
                        Content="🔹 Widget"
                        Height="34"
                        Width="100"
                        Margin="12,0,0,0"
                        Click="ShowMiniWidgetButton_OnClick" />

                <Button Grid.Column="2"
                        x:Name="OpenDataFolderButton"
                        Content="Otwórz folder danych"
                        Height="34"
                        Width="180"
                        Margin="12,0,0,0"
                        Click="OpenDataFolderButton_OnClick" />
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,12,0,12">
            <TabItem Header="Live">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Session Setup Row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Nazwa sesji" FontWeight="SemiBold" />
                            <TextBox x:Name="SessionNameTextBox" Height="34" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Język" FontWeight="SemiBold" />
                            <ComboBox x:Name="LanguageComboBox" Height="34">
                                <ComboBoxItem Content="Auto" Tag="auto" />
                                <ComboBoxItem Content="Polish" Tag="pl" />
                                <ComboBoxItem Content="English" Tag="en" />
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="2"
                                x:Name="StartStopButton"
                                Content="Start"
                                Height="34"
                                Margin="0,20,0,0"
                                Background="#10B981"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Click="StartStopButton_OnClick" />
                    </Grid>

                    <!-- Quick Settings Row -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Model" FontWeight="SemiBold" FontSize="11" />
                            <ComboBox x:Name="LiveModelComboBox" Height="32" DisplayMemberPath="Name" SelectedValuePath="Name" SelectionChanged="LiveModelComboBox_OnSelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <CheckBox x:Name="LiveTranscriptQuickToggle" Margin="0,16,0,0" Content="🔴 Live Transcript" VerticalAlignment="Center" Checked="LiveTranscriptQuickToggle_OnToggled" Unchecked="LiveTranscriptQuickToggle_OnToggled" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <CheckBox x:Name="AutoPunctuationQuickToggle" Margin="0,16,0,0" Content="📝 Auto Punctuation" VerticalAlignment="Center" Checked="AutoPunctuationQuickToggle_OnToggled" Unchecked="AutoPunctuationQuickToggle_OnToggled" />
                        </StackPanel>
                    </Grid>

                    <!-- Settings Preview Row -->
                    <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" CornerRadius="8" Background="#EEF2FF" BorderThickness="1" BorderBrush="#DDE3EF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Chunk Length" FontSize="10" Foreground="#4B5563" />
                                <TextBlock x:Name="PreviewChunkLengthTextBlock" Text="10s" FontWeight="SemiBold" Foreground="#1F2937" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Audio Buffer" FontSize="10" Foreground="#4B5563" />
                                <TextBlock x:Name="PreviewAudioBufferTextBlock" Text="2048 ramek" FontWeight="SemiBold" Foreground="#1F2937" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Plik niestandardowy" FontSize="10" Foreground="#4B5563" />
                                <TextBlock x:Name="PreviewCustomModelTextBlock" Text="Nie" FontWeight="SemiBold" Foreground="#1F2937" />
                            </StackPanel>

                            <Button Grid.Column="3" Margin="10,0,0,0" Content="Przejdź do ustawień" Click="GoToSettingsButton_OnClick" Height="34" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="10,8" CornerRadius="8" Background="#EEF2FF" BorderBrush="#DDE3EF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="11" Foreground="#4B5563" />
                                <TextBlock x:Name="StatusTextBlock" Text="Ready" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="10,8"
                                CornerRadius="8"
                                Background="#EEF2FF"
                                BorderBrush="#DDE3EF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Czas" FontSize="11" Foreground="#4B5563" />
                                <TextBlock x:Name="ElapsedTextBlock" Text="00:00:00" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="10,8"
                                CornerRadius="8"
                                Background="#EEF2FF"
                                BorderBrush="#DDE3EF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Poziom audio" FontSize="11" Foreground="#4B5563" />
                                <ProgressBar x:Name="AudioLevelBar" Minimum="0" Maximum="100" Height="14" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Deferred Transcription Row -->
                    <Border x:Name="DeferredTranscriptionBorder"
                            Grid.Row="3"
                            Margin="0,12,0,0"
                            Padding="12"
                            CornerRadius="8"
                            Background="#DBEAFE"
                            BorderBrush="#0EA5E9"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nagranie gotowe - transkrypcja poza nagraniem"
                                       FontWeight="SemiBold"
                                       Foreground="#0369A1"
                                       VerticalAlignment="Center" />

                            <Button x:Name="TranscribeNowButton"
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Content="▶ Transkrybuj teraz"
                                    Height="34"
                                    Background="#0EA5E9"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Click="TranscribeNowButton_OnClick" />

                            <ProgressBar x:Name="TranscriptionProgressBar"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,8,0,0"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="18"
                                         Visibility="Collapsed" />

                            <TextBlock x:Name="TranscriptionProgressTextBlock"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Margin="0,6,0,0"
                                       FontSize="11"
                                       Foreground="#0369A1" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Margin="0,12,0,0"
                            Padding="10"
                            CornerRadius="8"
                            Background="#FEF3C7"
                            BorderBrush="#F59E0B"
                            BorderThickness="1">
                        <TextBlock x:Name="WarningTextBlock"
                                   Text=""
                                   Foreground="#92400E"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBox Grid.Row="5"
                             x:Name="TranscriptTextBox"
                             Margin="0,12,0,0"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             IsReadOnly="True" />
                </Grid>
            </TabItem>

            <TabItem Header="Ustawienia">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Model Selection Section -->
                        <TextBlock Text="Model Whisper" FontWeight="SemiBold" />
                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModelComboBox" Height="34" DisplayMemberPath="Name" SelectedValuePath="Name" />
                            <Button Grid.Column="1" x:Name="RefreshModelsButton" Margin="10,0,0,0" Content="Odśwież" Click="RefreshModelsButton_OnClick" />
                            <Button Grid.Column="2" x:Name="DownloadModelButton" Margin="10,0,0,0" Content="Pobierz model" Click="DownloadModelButton_OnClick" />
                        </Grid>

                        <TextBlock Grid.Row="2" Text="Własny plik modelu (.bin)" Margin="0,12,0,0" FontWeight="SemiBold" />
                        <Grid Grid.Row="3" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CustomModelPathTextBox" Height="34" />
                            <Button Grid.Column="1" Margin="10,0,0,0" Content="Wybierz..." Click="BrowseModelButton_OnClick" />
                        </Grid>

                        <TextBlock Grid.Row="4" x:Name="ModelStatusTextBlock" Margin="0,12,0,0" Foreground="#1F2937" />
                        <ProgressBar Grid.Row="5" x:Name="DownloadProgressBar" Margin="0,6,0,0" Height="16" Minimum="0" Maximum="100" />

                        <!-- Live Transcript Option -->
                        <CheckBox Grid.Row="6" x:Name="EnableLiveTranscriptCheckBox" Margin="0,12,0,0" Content="Włącz live transkrypcję (może zużywać więcej zasobów)" VerticalAlignment="Top" />

                        <!-- Advanced Settings Section -->
                        <Border Grid.Row="7" Margin="0,24,0,0" Padding="12" CornerRadius="8" Background="#F3F4F6" BorderThickness="1" BorderBrush="#D1D5DB">
                            <StackPanel>
                                <TextBlock Text="Zaawansowane ustawienia wydajności" FontWeight="SemiBold" Foreground="#1F2937" />

                                <!-- Chunk Length Slider -->
                                <StackPanel Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Długość chunka (sekundy)" VerticalAlignment="Center">
                                            <TextBlock.ToolTip>
                                                <ToolTip>Jak często wysyłać audio do transkrypcji. Większe wartości = mniej CPU, ale transkrypcja później się zapisuje. Dla 8GB RAM: 15-20s</ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" x:Name="ChunkLengthValueTextBlock" Text="10s" TextAlignment="Right" Foreground="#4B5563" />
                                    </Grid>
                                    <Slider x:Name="ChunkLengthSlider" Margin="0,8,0,0" Minimum="3" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Height="20" />
                                </StackPanel>

                                <!-- Audio Buffer Slider -->
                                <StackPanel Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rozmiar bufora audio (ramki)" VerticalAlignment="Center">
                                            <TextBlock.ToolTip>
                                                <ToolTip>Maksymalnie ile ramek audio przechowywać w pamięci. Większe = bardziej stabilne dla słabszych komputerów, ale zużywa więcej RAM. Normalnie: 2048</ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" x:Name="AudioBufferValueTextBlock" Text="2048" TextAlignment="Right" Foreground="#4B5563" />
                                    </Grid>
                                    <Slider x:Name="AudioBufferSlider" Margin="0,8,0,0" Minimum="256" Maximum="4096" TickFrequency="256" IsSnapToTickEnabled="True" Height="20" />
                                </StackPanel>

                                <!-- GPU Acceleration Settings -->
                                <StackPanel Margin="0,12,0,0">
                                    <CheckBox x:Name="EnableGpuAccelerationCheckBox" Content="Włącz GPU acceleration" VerticalAlignment="Top" Checked="EnableGpuAccelerationCheckBox_OnToggled" Unchecked="EnableGpuAccelerationCheckBox_OnToggled">
                                        <CheckBox.ToolTip>
                                            <ToolTip>Włącz przyspieszenie GPU dla transkrypcji. Działa na NVIDIA (CUDA). AMD Vega 8 i Intel na Windows automatycznie używają CPU.</ToolTip>
                                        </CheckBox.ToolTip>
                                    </CheckBox>

                                    <StackPanel Margin="0,8,0,0" x:Name="GpuProviderPanel">
                                        <TextBlock Text="Tryb GPU" FontSize="11" Foreground="#4B5563" />
                                        <ComboBox x:Name="GpuProviderComboBox" Height="32" Margin="0,4,0,0" SelectionChanged="GpuProviderComboBox_OnSelectionChanged">
                                            <ComboBoxItem Content="Auto-detect (zalecane)" Tag="auto" />
                                            <ComboBoxItem Content="NVIDIA CUDA (RTX/GTX)" Tag="cuda" />
                                            <ComboBoxItem Content="AMD ROCm (tylko Linux)" Tag="rocm" />
                                            <ComboBoxItem Content="CPU (wyłącz GPU)" Tag="cpu" />
                                        </ComboBox>
                                        <TextBlock Margin="0,6,0,0" FontSize="10" Foreground="#6B7280" TextWrapping="Wrap"
                                                   Text="AMD Vega 8 / Intel Arc na Windows → automatycznie CPU (brak wsparcia GPU dla tych kart w tej wersji)" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Reset Button -->
                                <Button x:Name="ResetAdvancedSettingsButton" Margin="0,12,0,0" Padding="8,6" Width="200" HorizontalAlignment="Left" Content="Przywróć ustawienia domyślne" Click="ResetAdvancedSettingsButton_OnClick" />
                            </StackPanel>
                        </Border>

                        <!-- Save Button -->
                        <StackPanel Grid.Row="8" Margin="0,20,0,0">
                            <Button x:Name="SaveSettingsButton"
                                    Width="180"
                                    Height="34"
                                    Content="Zapisz ustawienia"
                                    Click="SaveSettingsButton_OnClick" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Sesje">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RefreshSessionsButton"
                                Content="Odśwież sesje"
                                Height="34"
                                Click="RefreshSessionsButton_OnClick" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Content="Folder sesji"
                                Height="34"
                                Click="OpenTranscriptsFolderButton_OnClick" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Content="Otwórz TXT"
                                Height="34"
                                Click="OpenSelectedTextButton_OnClick" />
                        <TextBlock Grid.Column="3"
                                   Margin="10,8,0,0"
                                   x:Name="SessionsInfoTextBlock"
                                   Foreground="#4B5563" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              Margin="0,12,0,0"
                              x:Name="SessionsDataGrid"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="220" />
                            <DataGridTextColumn Header="Start" Binding="{Binding StartLocal}" Width="160" />
                            <DataGridTextColumn Header="Czas" Binding="{Binding DurationText}" Width="90" />
                            <DataGridTextColumn Header="Model" Binding="{Binding ModelName}" Width="100" />
                            <DataGridTextColumn Header="Plik TXT" Binding="{Binding TextPath}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="FooterStatusTextBlock" Text="Gotowe." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
